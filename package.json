{
  "name": "kogoro",
  "description": "",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun build apps/cli/src/index.ts --outdir dist --target bun",
    "build:bin": "bun build --compile apps/cli/src/index.ts --outfile dist/kogoro",
    "check": "bun x tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "knip": "bun x knip --include exports,files,dependencies",
    "check:all": "biome check . && bun run knip && bun run check && bun test",
    "sandcastle": "npx tsx .sandcastle/main.ts",
    "start": "bun run apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.12",
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "knip": "^6.14.2",
    "lefthook": "^2.1.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
