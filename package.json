{
  "name": "kogoro",
  "version": "0.0.1",
  "description": "Kogoro is the ultimate companion for organizing and renaming your anime collection. Instantly match your media files with the AniDB database to rename them accurately, download artwork and cover images, fetch subtitles, and write metadata — all in just seconds. It’s intelligent, fast, and effortless to use.",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest --run",
    "format": "biome format --write",
    "lint": "biome lint --write"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.4",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "lucide-solid": "^0.553.0",
    "motion": "^12.23.24",
    "solid-js": "^1.9.10",
    "tailwind-merge": "^3.4.0"
  }
