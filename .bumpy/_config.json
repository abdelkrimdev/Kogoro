{
  "$schema": "https://raw.githubusercontent.com/dmno-dev/bumpy/main/packages/bumpy/config-schema.json",
  "baseBranch": "main",
  "changelog": "github",
  "fixed": [["@kogoro/cli", "@kogoro/gui"]],
