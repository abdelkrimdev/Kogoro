{
  "name": "@kogoro/cli",
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "kogoro": "src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:bin": "bun scripts/build-bin.ts",
    "check": "tsc --noEmit",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@kogoro/core": "workspace:*",
    "@kogoro/plugins": "workspace:*",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.35"
  }
}
